[Unit]
Description=Campus Assistant Gateway
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/campus
ExecStart=/usr/bin/java -jar /opt/campus/campus-assistant/campusswu-gateway/target/campusswu-gateway-1.0-SNAPSHOT.jar --server.port=8080
Restart=always
RestartSec=5
StandardOutput=append:/opt/campus/logs/gateway.log
StandardError=append:/opt/campus/logs/gateway.log

[Install]
WantedBy=multi-user.target
